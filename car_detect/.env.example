# SmartInspect-Vision 环境配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 基础配置
# ============================================
PROJECT_NAME=智检慧眼
API_PREFIX=/api/v1
VERSION=1.0.0

# 服务器配置
HOST=0.0.0.0
PORT=8000

# ============================================
# 文件路径配置
# ============================================
# BASE_DIR, UPLOAD_DIR, DB_PATH, LOG_DIR 使用默认值即可

# 文件上传限制
MAX_FILE_SIZE=10485760  # 10MB

# 日志配置
LOG_LEVEL=INFO

# ============================================
# 远程 YOLO 服务配置（分布式架构）
# ============================================

# 是否使用远程 YOLO 服务
# false = 本地推理（云服务器直接加载模型）
# true = 远程调用（云服务器通过 HTTP 请求本地电脑）
USE_REMOTE_YOLO=false

# 远程 YOLO 服务地址
# 本地测试：http://localhost:9000
# frp 方案：http://YOUR_SERVER_IP:9000
# ngrok 方案：https://abc123.ngrok.io
# Cloudflare 方案：https://yolo.your-domain.com
REMOTE_YOLO_URL=http://localhost:9000

# API 认证 Token（必须与本地服务一致）
# 建议使用强密码生成器生成
YOLO_API_TOKEN=your-secret-token-here-change-this

# 请求超时时间（秒）
REMOTE_YOLO_TIMEOUT=30

# ============================================
# 其他配置（预留）
# ============================================
# DASHSCOPE_API_KEY=sk-xxx  # 通义千问 API Key（如需 AI 报告）
